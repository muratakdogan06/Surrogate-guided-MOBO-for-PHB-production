# Copy to blocked_subsystem_rollup.yaml and edit.
# 00c_export_blocked_by_subsystem.py loads this file if present; otherwise built-in ROLLUP_RULES apply.
#
# Each row: category name + substrings matched (case-insensitive) against reaction.subsystem.
# First matching rule in the list wins (same order as in the file).

rollup_contains:
  - category: "Exchange reactions"
    substrings: ["exchange", "demand", "sink"]
  - category: "Transport"
    substrings: ["transport", "transporter", "diffusion"]
  - category: "Cofactor and vitamin metabolism"
    substrings: ["cofactor", "vitamin", "folate", "porphyrin"]
  - category: "Amino acid metabolism"
    substrings: ["amino acid", "protein", "peptide", "tRNA"]
  - category: "Carbohydrate metabolism"
    substrings: ["carbohydrate", "glycolysis", "pentose", "glycogen"]
